# Скопируйте этот файл в .env и заполните значения:
# cp .env.example .env

# API ключ для LLM-аналитика (опционально)
# Без этого ключа dashboard работает в rule-based режиме
OPENAI_API_KEY=

# Кастомный OpenAI-совместимый endpoint (опционально)
# Если не задан — используется api.openai.com
# Пример: LLM_BASE_URL=https://llm.lambda.coredump.ru/v1
LLM_BASE_URL=https://llm.lambda.coredump.ru/v1

# Модель (опционально, по умолчанию gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini
